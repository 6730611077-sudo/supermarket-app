<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Supermarket Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Supermarket Admin</a>
            <form action="/" method="GET" class="d-flex w-50 mx-auto">
                <input class="form-control me-2" type="search" name="search" placeholder="Search product..." value="<%= typeof search != 'undefined' ? search : '' %>">
                <button class="btn btn-outline-light" type="submit">Search</button>
            </form>
            <a href="/form" class="btn btn-success">+ Add New Product</a>
        </div>
    </nav>

    <div class="container">
        <% if (success === 'added') { %> <div class="alert alert-success">Product added successfully!</div> <% } %>
        <% if (success === 'updated') { %> <div class="alert alert-success">Product updated successfully!</div> <% } %>
        <% if (success === 'deleted') { %> <div class="alert alert-warning">Product deleted successfully!</div> <% } %>

        <table class="table table-bordered table-striped text-center align-middle bg-white shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                <tr>
                    <td><img src="/uploads/<%= product.image %>" width="60" class="rounded"></td>
                    <td><%= product.name %></td>
                    <td><%= product.category %></td>
                    <td><%= product.price %> ฿</td>
                    <td>
                        <% if(product.stock === 0) { %>
                            <span class="badge bg-danger">Out of Stock</span>
                        <% } else { %>
                            <%= product.stock %>
                        <% } %>
                    </td>
                    <td>
                        <a href="/form?id=<%= product.id %>" class="btn btn-warning btn-sm">Edit</a>
                        <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#delModal<%= product.id %>">Delete</button>
                    </td>
                </tr>

                
                <div class="modal fade" id="delModal<%= product.id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <div class="modal-body text-start">
                        คุณแน่ใจหรือไม่ว่าต้องการลบรายการ "<%= product.name %>"?
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <a href="/delete/<%= product.id %>" class="btn btn-danger">Yes, Delete</a>
                      </div>
                    </div>
                  </div>
                </div>
                <% }) %>
            </tbody>
        </table>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
