<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= product ? 'Edit Product' : 'Add New Product' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card mx-auto shadow-sm" style="max-width: 600px;">
            <div class="card-body p-4">
                <h3 class="text-center mb-4"><%= product ? 'Edit Product' : 'Add New Product' %></h3>
                <form action="<%= product ? '/update' : '/add' %>" method="POST" enctype="multipart/form-data">
                    <% if(product) { %> <input type="hidden" name="id" value="<%= product.id %>"> <% } %>
                    
                    <div class="mb-3">
                        <label class="form-label">Product Name</label>
                        <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <input type="text" name="category" class="form-control" value="<%= product ? product.category : '' %>" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Price</label>
                            <input type="number" step="0.01" min="0" name="price" class="form-control" value="<%= product ? product.price : '' %>" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Stock</label>
                            <input type="number" min="0" name="stock" class="form-control" value="<%= product ? product.stock : '' %>" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Product Image</label>
                        <input type="file" name="image" class="form-control" accept="image/*" onchange="previewImg(event)" <%= product ? '' : 'required' %>>
                        
                        <div class="mt-3 text-center">
                            <img id="preview" src="<%= product && product.image ? '/uploads/' + product.image : '' %>" 
                                 style="max-width: 150px; <%= product && product.image ? 'display:block; margin:auto;' : 'display:none;' %>" class="rounded border">
                        </div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a href="/" class="btn btn-secondary px-4">Cancel</a>
                        <button type="submit" class="btn btn-success px-4">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        function previewImg(event) {
            const reader = new FileReader();
            reader.onload = function(){
                const output = document.getElementById('preview');
                output.src = reader.result;
                output.style.display = 'block';
                output.style.margin = 'auto';
            };
            if(event.target.files[0]) reader.readAsDataURL(event.target.files[0]);
        }
    </script>
</body>
</html>
